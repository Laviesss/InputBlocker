<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/amoled_surface"
    app:cardCornerRadius="20dp"
    app:strokeColor="@color/accent_purple"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Color preview bar for region visual -->
        <View
            android:id="@+id/view_region_preview"
            android:layout_width="6dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@color/accent_green"
            android:alpha="0.7" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_region_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Region #1"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_region_coords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="(0, 0) - (100, 100)"
                android:textColor="@color/amoled_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_region_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Size: 100x100"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remove_region"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:text="X"
            android:textColor="@color/accent_red"
            android:textSize="18sp"
            android:textStyle="bold"
            app:rippleColor="@color/accent_red" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
