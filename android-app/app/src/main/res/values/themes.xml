        <item name="android:navigationBarColor">@color/light_background</item>
    </style>

    <style name="Theme.InputBlocker.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">#1976D2</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">#388E3C</item>
        <item name="colorOnSecondary">#FFFFFF</item>
