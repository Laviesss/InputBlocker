#!/sbin/sh
# InputBlocker - Magisk Module Installer
# Blocks ghost taps and unwanted touch inputs

SKIPUNZIP=1

# UI helpers
ui_print() { echo "$1"; }
abort() { ui_print "ERROR: $1"; exit 1; }

ui_print ""
ui_print "================================"
ui_print "  InputBlocker Module"
ui_print "  by Laviesss"
ui_print "================================"
ui_print ""

# Extract module files
ui_print "- Extracting module files..."
unzip -o "$ZIPFILE" -x "META-INF/*" -d "$MODPATH" >&2

# Set permissions
ui_print "- Setting permissions..."
set_perm_recursive "$MODPATH" root root 0755 0644
set_perm "$MODPATH/service.sh" root root 0755

# Create config directory
mkdir -p "$MODPATH/config"

ui_print ""
ui_print "- Installation complete!"
ui_print "- Reboot to activate."
ui_print ""