#!/sbin/sh
# InputBlocker - Magisk Module Installer
# Blocks ghost taps and unwanted touch inputs

SKIPUNZIP=1

# UI helpers
ui_print() { echo "$1"; }
abort() { ui_print "ERROR: $1"; exit 1; }

ui_print ""
ui_print "================================"
ui_print "  InputBlocker Module"
ui_print "  by Laviesss"
ui_print "================================"
ui_print ""

# Extract module files (excluding META-INF)
unzip -o "$ZIPFILE" -x "META-INF/*" -d "$MODPATH" >&2

# Create directories
mkdir -p "$MODPATH/config"
mkdir -p "$MODPATH/system/bin"

# Set permissions
set_perm_recursive "$MODPATH" root root 0755 0644
set_perm "$MODPATH/service.sh" root root 0755
set_perm "$MODPATH/customize.sh" root root 0755 2>/dev/null || true
set_perm "$MODPATH/system/bin/inputblocker" root root 0755

# Create default config if not exists
if [ ! -f "$MODPATH/config/blocked_regions.conf" ]; then
    cat > "$MODPATH/config/blocked_regions.conf" << 'EOF'
enabled=1
force_safe_mode=0
EOF
    set_perm "$MODPATH/config/blocked_regions.conf" root root 0644
fi

ui_print ""
ui_print "- Installation complete!"
ui_print "- Reboot to activate."
ui_print ""