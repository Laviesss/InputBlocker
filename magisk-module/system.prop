# InputBlocker System Properties
# These properties configure the module behavior

# Module enabled flag (0=disabled, 1=enabled)
persist.inputblocker.enabled=1

# Log level (0=off, 1=error, 2=info, 3=debug)
persist.inputblocker.loglevel=2

# Config file path (auto-detected on boot based on root manager)
persist.inputblocker.config=/data/adb/modules/inputblocker/config/blocked_regions.conf
