#!/sbin/sh
#########################################################################################
# InputBlocker - Root Module Update Binary
# Handles installation through root manager
#########################################################################################

MODDIR="${0%/*}"
TMPDIR="/dev/tmp/inputblocker"

install() {
    ui_print "- Installing InputBlocker..."
    
    mkdir -p "$TMPDIR"
    cd "$TMPDIR"
    
    mkdir -p "$MODDIR/system/bin"
    mkdir -p "$MODDIR/system/lib"
    mkdir -p "$MODDIR/config"
    mkdir -p "$MODDIR/common"
    
    if [ ! -f "$MODDIR/config/blocked_regions.conf" ]; then
        cat > "$MODDIR/config/blocked_regions.conf" << 'EOF'
# InputBlocker Configuration
# Format: x1,y1,x2,y2 (top-left to bottom-right coordinates)
# enabled=1 (1=enable, 0=disable)

enabled=1

# Add blocked regions below

EOF
    fi
    
    ui_print "- Setting permissions..."
    set_perm_recursive "$MODDIR" 0 0 0755 0644
}

print_modname() {
  ui_print "****************************************"
  ui_print "    InputBlocker - Ghost Tap Blocker    "
  ui_print "****************************************"
}

ui_print() {
  echo "$1"
}

# Main
print_modname
install

ui_print ""
ui_print "Installation complete!"
ui_print "Run 'inputblocker' in terminal for commands"
ui_print "Companion app will be installed automatically"
ui_print ""
